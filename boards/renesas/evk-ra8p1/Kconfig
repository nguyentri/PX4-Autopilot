# Renesas EVK-RA8P1 board configuration
# Minimal flight controller: IMU + PWM + RC + Telemetry

config BOARD_RENESAS_EVK_RA8P1
	bool \"Renesas EVK-RA8P1\"
	depends on ARCH_CHIP_R7KA8P1KFLCAC
	select ARCH_HAVE_PWM
	select MODULE_SENSORS
	select DRIVERS_IMU_INVENSENSE_ICM20948
	---help---
		Enable support for the Renesas EVK-RA8P1 development board.
		Minimal configuration with ICM20948 IMU on SPI.

if BOARD_RENESAS_EVK_RA8P1

config EVK_RA8P1_HAVE_IMU
	bool \"Enable ICM20948 IMU\"
	default y
	---help---
		Enable the ICM20948 9-axis IMU on the GY-912 module.

config EVK_RA8P1_HAVE_MAG
	bool \"Enable AK09916 Magnetometer\"
	default y
	depends on EVK_RA8P1_HAVE_IMU
	---help---
		Enable the AK09916 magnetometer (part of ICM20948).

endif # BOARD_RENESAS_EVK_RA8P1
