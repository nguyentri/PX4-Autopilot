#
# NuttX Configuration for RA8P1 CM33 IO Processor
#
# This configuration enables the peripherals required for PX4IO functionality
# on the Cortex-M33 core of the RA8P1 dual-core MCU.
#

#
# Architecture Selection
#
CONFIG_ARCH="arm"
CONFIG_ARCH_ARM=y
CONFIG_ARCH_BOARD="evk-ra8p1"
CONFIG_ARCH_BOARD_EVK_RA8P1=y
CONFIG_ARCH_CHIP="ra8"
CONFIG_ARCH_CHIP_RA8=y
CONFIG_ARCH_CHIP_R7KA8P1KFLCAC=y
CONFIG_ARCH_CORTEXM33=y
CONFIG_ARCH_STACKDUMP=y
CONFIG_ARMV8M_DCACHE=y
CONFIG_ARMV8M_DTCM=y
CONFIG_ARMV8M_ICACHE=y
CONFIG_ARMV8M_ITCM=y
CONFIG_ARMV8M_TOOLCHAIN_GNU_EABI=y
# CONFIG_ARMV8M_USEBASEPRI is not set

#
# Board Definition (use NuttX evk-ra8p1 board)
#
CONFIG_BOARD_LOOPSPERMSEC=200000

#
# ARM Mode - Must be THUMB for Cortex-M33
#
CONFIG_ARCH_THUMB=y

#
# Memory Configuration
#
# CM33 Memory Layout:
# - ITCM: 0x20100000, 64KB (code)
# - DTCM: 0x20110000, 64KB (data, stacks)
# - SRAM: 0x22000000, 896KB (heap)
# - IPC:  0x220E0000, 64KB (shared memory, non-cacheable)
#
CONFIG_RAM_START=0x20110000
CONFIG_RAM_SIZE=65536
CONFIG_ARCH_INTERRUPTSTACK=2048
CONFIG_IDLETHREAD_STACKSIZE=1024
CONFIG_RA_DTCM=16
CONFIG_RA_ITCM=16

#
# FPU Configuration
#
CONFIG_ARCH_FPU=y
CONFIG_ARMV8M_LAZYFPU=y

#
# Build Configuration
#
CONFIG_BINFMT_DISABLE=y
CONFIG_DEBUG_FULLOPT=y
CONFIG_DEBUG_SYMBOLS=y
CONFIG_RAW_BINARY=y
CONFIG_INTELHEX_BINARY=y
CONFIG_HAVE_CXX=y
CONFIG_HAVE_CXXINITIALIZE=y

# Disable LED debugging to avoid undefined board_autoled_* references
CONFIG_ARCH_LEDS=n

#
# NuttX Features
#
CONFIG_BUILTIN=y
CONFIG_BUILD_FLAT=y
CONFIG_USER_ENTRYPOINT="nsh_main"
CONFIG_INIT_ENTRYPOINT="nsh_main"
CONFIG_INIT_STACKSIZE=2048
CONFIG_DEV_CONSOLE=y
CONFIG_FDCLONE_STDIO=y
CONFIG_NSH_BUILTIN_APPS=y
CONFIG_NSH_ARCHINIT=y
CONFIG_NSH_READLINE=y
CONFIG_SCHED_HPWORK=y
CONFIG_SCHED_LPWORK=y
CONFIG_SCHED_WORKQUEUE=y
CONFIG_PRIORITY_INHERITANCE=y
CONFIG_SCHED_BACKTRACE=y

#
# Timing and Clocks
#
CONFIG_USEC_PER_TICK=1000
CONFIG_RR_INTERVAL=0
CONFIG_START_YEAR=2026
CONFIG_START_MONTH=1
CONFIG_START_DAY=1
CONFIG_BOARD_LOOPSPERMSEC=200000

#
# Memory Management
#
CONFIG_MM_REGIONS=2
CONFIG_MM_SMALL=y

#
# Clock Configuration
#
CONFIG_RA_CLOCK_PLL1P=y

#
# RA8 Peripheral Drivers
#

# GPT Timers (Motor PWM/DShot)
CONFIG_RA_GPT=y
CONFIG_RA_GPT3=y
CONFIG_RA_GPT5=y
CONFIG_RA_GPT11=y
CONFIG_RA_GPT13=y

# DMAC (DShot frame generation)
CONFIG_RA_DMAC=y
CONFIG_RA_DMAC1=y

# ADC_B (Battery monitoring)
CONFIG_RA_ADC_B=y

# POEG (Emergency stop)
CONFIG_RA_POEG=y

#
# IPC Configuration (shared memory with CM85)
#
CONFIG_RA_IPC=y
CONFIG_RA_IPC_CH0_ENABLE=y
CONFIG_RA_IPC_CH1_ENABLE=y
CONFIG_RA_CPU_CORE_CM33=y
CONFIG_RA_IPC_DEBUG=y
CONFIG_RA_IPC_USE_NMI=y

#
# Serial Configuration (Debug console via SCI)
#
CONFIG_SERIAL=y
CONFIG_STANDARD_SERIAL=y
CONFIG_SCI0_SERIALDRIVER=y
CONFIG_SCI0_SERIAL_CONSOLE=y
CONFIG_SCI0_RXBUFSIZE=256
CONFIG_SCI0_TXBUFSIZE=256
CONFIG_SCI0_BAUD=115200
CONFIG_SCI0_BITS=8
CONFIG_SCI0_PARITY=0
CONFIG_SCI0_2STOP=0
CONFIG_RA_SCI0_UART=y
CONFIG_DEV_CONSOLE=y
CONFIG_SERIAL_CONSOLE=y

#
# NSH Configuration
#
CONFIG_SYSTEM_NSH=y
CONFIG_SYSTEM_NSH_PRIORITY=100
CONFIG_SYSTEM_NSH_STACKSIZE=2048
CONFIG_NSH_CONSOLE=y
CONFIG_NSH_LIBRARY=y

#
# Proc FS
#
CONFIG_FS_PROCFS=y
CONFIG_FS_ROMFS=y
CONFIG_NSH_ROMFSETC=y
CONFIG_NSH_ROMFSSECTSIZE=64
CONFIG_LIBC_LOCALTIME=y
CONFIG_LINE_MAX=64

#
# Spinlock (for multi-core synchronization)
#
CONFIG_SPINLOCK=y

#
# PWM Driver
#
CONFIG_PWM=y

#
# Debug features
#
CONFIG_DEBUG_ALERT=y
CONFIG_DEBUG_ERROR=y
CONFIG_DEBUG_WARN=y
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_FEATURES=y
