#!/bin/sh
#
# Renesas EVK-RA8P1 board sensors init
#------------------------------------------------------------------------------

# Initial power stabilization delay - wait for sensors to power up
# Critical: ICM20948 needs 100ms from power-on to be ready for communication
usleep 100000

# Start ADC driver for battery monitoring (when available)
# board_adc start

# Start IMU on SPI1 - ICM20948 9-axis sensor with integrated magnetometer
# -s: SPI mode, -b 1: SPI bus 1, -R 0: no rotation, -M 1: enable magnetometer (AK09916)
# Note: Device will auto-detect on SPI bus 1, CS0 (P804), DRDY on P006
if icm20948 start -s -b 1 -R 0 -M 1
then
        echo "ICM20948 IMU initialized successfully"
else
        echo "ERROR: ICM20948 IMU initialization failed!"
fi

# Delay after IMU initialization - allow ICM20948 to stabilize
# Important: Give time for DRDY interrupt to be configured and sensor to settle
usleep 50000

# Start Barometer on SPI1 - BMP388 pressure sensor
# -s: SPI mode, -b 1: SPI bus 1, -T: device type ID
# Device type 6553601 = (1<<24 | DRV_BARO_DEVTYPE_BMP388) for proper identification
if bmp388 start -s -b 1 -T 6553601
then
        echo "BMP388 barometer initialized successfully"
else
        echo "ERROR: BMP388 barometer initialization failed!"
fi

# Short delay after barometer initialization
usleep 10000

# Start PWM output driver for motor control
# This initializes the GPT timers for the 4 motor channels
if pwm_out start
then
        echo "PWM output driver started"
else
        echo "ERROR: PWM output driver failed to start!"
fi

# Configure PWM outputs for standard ESC operation
# Sets PWM mode (not OneShot, not DShot)
pwm_out mode_pwm

# Set PWM output frequency to 400 Hz (standard for ESCs)
# This configures all 4 channels (GPT0, GPT2, GPT3, GPT4) to 400Hz
pwm_out rate -a -r 400

# DO NOT auto-arm the PWM outputs here for safety
# Arming should only happen through commander when system is ready
# The following line is intentionally removed:
# pwm_out arm

echo "Board sensor initialization complete"
