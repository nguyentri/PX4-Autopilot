#!/bin/sh
#
# Renesas EVK-RA8P1 board main initialization
#------------------------------------------------------------------------------

# Load board-specific parameters
. /etc/init.d/rc.board_defaults

# Start board sensors
. /etc/init.d/rc.board_sensors

# Start LED driver
led_control start

# Start Commander
commander start

echo "EVK-RA8P1 board initialization complete"
