#!/bin/sh
#
# Renesas EVK-RA8P1 board defaults
# Minimal configuration for RC + Telemetry flight
#------------------------------------------------------------------------------

# Set the default system autostart for a quadrotor X configuration
param set-default SYS_AUTOSTART 4001

# Disable all circuit breaker checks for minimal config
param set-default CBRK_SUPPLY_CHK 894281
param set-default CBRK_USB_CHK 197848
param set-default CBRK_BUZZER 782090

# Enable arming without GPS (no GPS on this board)
param set-default COM_ARM_WO_GPS 1

# Disable GPS requirement in EKF2
param set-default EKF2_GPS_CTRL 0

# Use RAM-only dataman backend (no filesystem/SD card)
param set-default SYS_DM_BACKEND 1

# RC input mode - RC receiver
param set-default COM_RC_IN_MODE 0

# Disable external I2C sensor probing
param set-default SENS_EXT_I2C_PRB 0

# EKF2 settings for no-GPS and no-barometer operation
param set-default EKF2_HGT_REF 0
param set-default EKF2_BARO_CTRL 0

# Enable magnetometer (AK09916 embedded in ICM20948)
param set-default SYS_HAS_MAG 1
param set-default EKF2_MAG_TYPE 0  # 0=Automatic, use mag for heading

# Disable SD card check
param set-default COM_ARM_SDCARD 0

# RC channel mapping (standard mode)
param set-default RC_MAP_THROTTLE 3
param set-default RC_MAP_ROLL 1
param set-default RC_MAP_PITCH 2
param set-default RC_MAP_YAW 4
param set-default RC_MAP_FLTMODE 5

# Flight mode configuration - enable stabilized mode
param set-default COM_FLTMODE1 0   # Manual/Stabilized mode
param set-default COM_FLTMODE2 2   # Altitude mode
param set-default COM_FLTMODE3 3   # Position mode
param set-default COM_FLTMODE4 0   # Manual/Stabilized mode
param set-default COM_FLTMODE5 0   # Manual/Stabilized mode
param set-default COM_FLTMODE6 0   # Manual/Stabilized mode

# Disable unused features
param set-default NAV_DLL_ACT 0
param set-default NAV_RCL_ACT 0

# Disable load monitoring (not compiled in)
param set-default COM_CPU_MAX -1

# Disable barometer requirement (not connected)
param set-default SYS_HAS_BARO 0

# Enable magnetometer calibration checks
param set-default COM_ARM_MAG_STR 2  # Strength check (2=relaxed)
param set-default COM_ARM_MAG_ANG 30 # Maximum angle deviation (degrees)

# Set attitude source to not require external vision/mocap
param set-default SYS_MC_EST_GROUP 2

# PWM output frequency - 400Hz for standard ESCs
param set-default PWM_MAIN_RATE 400

# PWM channel function assignments (Motor 1-4)
param set-default PWM_MAIN_FUNC1 101  # Motor 1 (Front Right) - GPT3/P912
param set-default PWM_MAIN_FUNC2 102  # Motor 2 (Rear Left) - GPT5/P915
param set-default PWM_MAIN_FUNC3 103  # Motor 3 (Front Left) - GPT11/P903
param set-default PWM_MAIN_FUNC4 104  # Motor 4 (Rear Right) - GPT13/P515

# PWM pulse width limits (microseconds)
param set-default PWM_MAIN_MIN1 1100
param set-default PWM_MAIN_MIN2 1100
param set-default PWM_MAIN_MIN3 1100
param set-default PWM_MAIN_MIN4 1100
param set-default PWM_MAIN_MAX1 1900
param set-default PWM_MAIN_MAX2 1900
param set-default PWM_MAIN_MAX3 1900
param set-default PWM_MAIN_MAX4 1900

# Disarmed PWM values (motor stopped)
param set-default PWM_MAIN_DIS1 1000
param set-default PWM_MAIN_DIS2 1000
param set-default PWM_MAIN_DIS3 1000
param set-default PWM_MAIN_DIS4 1000

# Multicopter rate controller tuning (basic stabilization)
# Roll rate control
param set-default MC_ROLLRATE_P 0.15
param set-default MC_ROLLRATE_I 0.2
param set-default MC_ROLLRATE_D 0.003
param set-default MC_ROLLRATE_K 1.0
param set-default MC_ROLLRATE_MAX 220.0

# Pitch rate control
param set-default MC_PITCHRATE_P 0.15
param set-default MC_PITCHRATE_I 0.2
param set-default MC_PITCHRATE_D 0.003
param set-default MC_PITCHRATE_K 1.0
param set-default MC_PITCHRATE_MAX 220.0

# Yaw rate control
param set-default MC_YAWRATE_P 0.2
param set-default MC_YAWRATE_I 0.1
param set-default MC_YAWRATE_D 0.0
param set-default MC_YAWRATE_K 1.0
param set-default MC_YAWRATE_MAX 200.0

# Attitude control
param set-default MC_ROLL_P 6.5
param set-default MC_PITCH_P 6.5
param set-default MC_YAW_P 2.8

# Enable stabilization on all axes
param set-default MC_ACRO_EXPO 0.69
param set-default MC_ACRO_EXPO_Y 0.69
param set-default MC_ACRO_SUPEXPO 0.7
param set-default MC_ACRO_SUPEXPOY 0.7

# Control allocation - quadrotor X configuration
param set-default CA_ROTOR_COUNT 4
param set-default CA_ROTOR0_PX 0.15
param set-default CA_ROTOR0_PY 0.15
param set-default CA_ROTOR0_KM 0.05
param set-default CA_ROTOR1_PX -0.15
param set-default CA_ROTOR1_PY -0.15
param set-default CA_ROTOR1_KM 0.05
param set-default CA_ROTOR2_PX 0.15
param set-default CA_ROTOR2_PY -0.15
param set-default CA_ROTOR2_KM -0.05
param set-default CA_ROTOR3_PX -0.15
param set-default CA_ROTOR3_PY 0.15
param set-default CA_ROTOR3_KM -0.05

# Hover thrust estimation
param set-default MPC_THR_HOVER 0.5

# Enable arming with RC control
param set-default COM_RC_OVERRIDE 0
param set-default COM_RC_ARM_HYST 1000
