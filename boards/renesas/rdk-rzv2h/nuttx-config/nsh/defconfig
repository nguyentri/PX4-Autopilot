#
# RDK-RZV2H Board Configuration for PX4
# Cortex-R8 Core 0 configuration
#
# CONFIG_DISABLE_ENVIRON is not set
# CONFIG_DISABLE_PSEUDOFS_OPERATIONS is not set
# CONFIG_DISABLE_PTHREAD is not set
# CONFIG_NSH_DISABLEBG is not set
# CONFIG_NSH_DISABLE_CAT is not set
# CONFIG_NSH_DISABLE_CP is not set
# CONFIG_NSH_DISABLE_DF is not set
# CONFIG_NSH_DISABLE_ECHO is not set
# CONFIG_NSH_DISABLE_ENV is not set
# CONFIG_NSH_DISABLE_FREE is not set
# CONFIG_NSH_DISABLE_HELP is not set
# CONFIG_NSH_DISABLE_LS is not set
# CONFIG_NSH_DISABLE_PS is not set
# CONFIG_NSH_DISABLE_SLEEP is not set
CONFIG_ARCH="arm"
CONFIG_ARCH_ARM=y
CONFIG_ARCH_BOARD="rdk-rzv2h"
CONFIG_ARCH_BOARD_RDK_RZV2H=y
CONFIG_ARCH_CHIP="rzv"
CONFIG_ARCH_CHIP_RZV=y
CONFIG_ARCH_CHIP_R9A09G057=y
CONFIG_ARCH_STACKDUMP=y
CONFIG_ARMV7R_DCACHE=y
CONFIG_ARMV7R_DTCM=y
CONFIG_ARMV7R_ICACHE=y
CONFIG_ARMV7R_ITCM=y
CONFIG_BOARD_LOOPSPERMSEC=200000
CONFIG_RZV2H_BUILD_CR8_0=y
CONFIG_RZV_CLOCK_PLL=y
CONFIG_RZV_GTM=y
CONFIG_RZV_GTM0_TIMER=y
CONFIG_RZV_GTM_CLOCK_FREQUENCY=120000000
CONFIG_RZV_PCLK_FREQUENCY=120000000
CONFIG_RZV_DTCM=16
CONFIG_RZV_ITCM=16
CONFIG_RAM_SIZE=524288
CONFIG_RAM_START=0x22060000
CONFIG_RAW_BINARY=y
CONFIG_SPINLOCK=y
CONFIG_BUILTIN=y
CONFIG_BUILD_FLAT=y
CONFIG_DEV_CONSOLE=y
CONFIG_DEBUG_ALERT=y
CONFIG_DEBUG_ERROR=y
CONFIG_DEBUG_FEATURES=y
CONFIG_DEBUG_FULLOPT=y
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_SYMBOLS=y
CONFIG_DEBUG_WARN=y
CONFIG_FS_DEVFS=y
CONFIG_FS_LITTLEFS=y
CONFIG_FS_PROCFS=y
CONFIG_FS_ROMFS=y
CONFIG_HAVE_CXX=y
CONFIG_HAVE_CXXINITIALIZE=y
CONFIG_IDLETHREAD_STACKSIZE=2048
CONFIG_INIT_ENTRYPOINT="nsh_main"
CONFIG_INTELHEX_BINARY=y
CONFIG_LIBC_FLOATINGPOINT=y
CONFIG_LIBC_LOCALTIME=y
CONFIG_MAX_TASKS=32
CONFIG_MAX_TASK_ARGS=8
CONFIG_TASK_NAME_SIZE=24
CONFIG_PTHREAD_STACK_MIN=512
CONFIG_PREALLOC_TIMERS=50
CONFIG_PRIORITY_INHERITANCE=y
CONFIG_NSH_ARCHINIT=y
CONFIG_NSH_BUILTIN_APPS=y
CONFIG_NSH_CONSOLE=y
CONFIG_NSH_FILEIOSIZE=512
CONFIG_NSH_LIBRARY=y
CONFIG_NSH_READLINE=y

# Core Specific Configuration (CR8 Core 0)
CONFIG_RZV2H_BUILD_CR8_0=y

# Clock Configuration
CONFIG_RZV_CLOCK_PLL=y

# PWM Configuration (GPT Timers)
CONFIG_PWM=y
CONFIG_RZV_GPT=y
CONFIG_RZV_GPT6=y
CONFIG_RZV_GPT7=y
CONFIG_RZV_GPT9=y
CONFIG_RZV_GPT10=y
CONFIG_RDK_RZV2H_XSPI_PARAMFS=y

# Serial Configuration
CONFIG_RZV_SCI3=y
# SCI4: TFmini LiDAR (/dev/ttyS4)
# SCI5: MAVLink telemetry (/dev/ttyS5)
# SCI6: SBUS RC input (/dev/ttyS6)
# SCI9: GPS M10 (/dev/ttyS9)
CONFIG_RZV_SCI4=y
CONFIG_RZV_SCI5=y
CONFIG_RZV_SCI6=y
CONFIG_RZV_SCI9=y
CONFIG_SERIAL=y
CONFIG_STANDARD_SERIAL=y

CONFIG_SCI3_SERIALDRIVER=y
CONFIG_SCI3_RXBUFSIZE=256
CONFIG_SCI3_TXBUFSIZE=256
CONFIG_SCI3_BAUD=115200
CONFIG_SCI3_BITS=8
CONFIG_SCI3_PARITY=0
CONFIG_SCI3_2STOP=0

CONFIG_SCI4_SERIALDRIVER=y
CONFIG_SCI4_RXBUFSIZE=256
CONFIG_SCI4_TXBUFSIZE=256
CONFIG_SCI4_BAUD=115200
CONFIG_SCI4_BITS=8
CONFIG_SCI4_PARITY=0
CONFIG_SCI4_2STOP=0

CONFIG_SCI5_SERIALDRIVER=y
CONFIG_SCI5_RXBUFSIZE=256
CONFIG_SCI5_TXBUFSIZE=256
CONFIG_SCI5_BAUD=57600
CONFIG_SCI5_BITS=8
CONFIG_SCI5_PARITY=0
CONFIG_SCI5_2STOP=0

CONFIG_SCI6_SERIALDRIVER=y
CONFIG_SCI6_RXBUFSIZE=256
CONFIG_SCI6_TXBUFSIZE=256
CONFIG_SCI6_BAUD=100000
CONFIG_SCI6_BITS=8
CONFIG_SCI6_PARITY=2
CONFIG_SCI6_2STOP=1

CONFIG_SCI9_SERIALDRIVER=y
CONFIG_SCI9_RXBUFSIZE=256
CONFIG_SCI9_TXBUFSIZE=256
CONFIG_SCI9_BAUD=115200
CONFIG_SCI9_BITS=8
CONFIG_SCI9_PARITY=0
CONFIG_SCI9_2STOP=0

CONFIG_DEV_CONSOLE=y
CONFIG_DEV_SIMPLE_ADDRENV=y
CONFIG_SERIAL_RTT=y
CONFIG_SERIAL_RTT0=y
CONFIG_SERIAL_RTT_CONSOLE=y
CONFIG_SERIAL_RTT_CONSOLE_CHANNEL=0
CONFIG_SERIAL_RTT_POLLING_INTERVAL=1000
CONFIG_SERIAL_CONSOLE=y
CONFIG_SYSLOG_RTT=y
CONFIG_SEGGER_RTT=y
CONFIG_SEGGER_RTT_BUFFER_SIZE_UP=8192
CONFIG_SEGGER_RTT_BUFFER_SIZE_DOWN=1024
CONFIG_SEGGER_RTT_PRINTF=y
CONFIG_SEGGER_RTT_PRINTF_BUFFER_SIZE=2048

# SPI Configuration (for MPU9250 IMU)
CONFIG_SPI=y
CONFIG_RZV_SPI=y
CONFIG_RZV_SPI0=y
CONFIG_SPI_EXCHANGE=y

# I2C Configuration
#
# The barometer is wired to SCI7 simple-I2C pins P7_6/P7_7, but the current
# RZV NuttX Kconfig only exposes RIIC0-3 and SCI simple-I2C0-3. Keep generic
# I2C enabled for PX4 and leave SCI7 hardware validation as the next driver enablement item.
CONFIG_I2C=y

# ADC Configuration
#
# Battery ADC channels are intentionally disabled in board_config.h for this
# v1 port; the lower-half driver has only a top-level RZV_ADC Kconfig symbol.
CONFIG_ANALOG=y
CONFIG_ADC=y
CONFIG_RZV_ADC=y
CONFIG_ADC_FIFOSIZE=8

# DMA Configuration (available, but not bound to DShot/PWM in v1)
CONFIG_ARCH_DMA=y
CONFIG_RZV_DMAC=y

# CR8-0 <-> CA55 OpenAMP/RPMsg transport.
# The board starts the RZ/V2H transport during bring-up and exposes the
# rpmsg-service-0 channel through /dev/ipcc0 for PX4-side clients.
CONFIG_EXPERIMENTAL=y
CONFIG_OPENAMP=y
CONFIG_RPTUN=y
CONFIG_RPTUN_THREAD=y
CONFIG_RZV_OPENAMP=y
CONFIG_RZV_IPC_IPCC=y
CONFIG_IPCC=y
CONFIG_IPCC_BUFFERED=y
CONFIG_IPCC_NPOLLWAITERS=4

# Scheduler Configuration
CONFIG_SCHED_BACKTRACE=y
CONFIG_SCHED_HPWORK=y
CONFIG_SCHED_HPWORKSTACKSIZE=1800
CONFIG_SCHED_INSTRUMENTATION=y
CONFIG_SCHED_INSTRUMENTATION_EXTERNAL=y
CONFIG_SCHED_INSTRUMENTATION_SWITCH=y
CONFIG_SCHED_LPWORK=y
CONFIG_SCHED_LPWORKSTACKSIZE=2032
CONFIG_SCHED_WAITPID=y
CONFIG_SEM_PREALLOCHOLDERS=16
CONFIG_FDCLONE_STDIO=y
CONFIG_SIG_DEFAULT=y
CONFIG_SIG_SIGALRM_ACTION=y
CONFIG_SIG_SIGUSR1_ACTION=y
CONFIG_SIG_SIGUSR2_ACTION=y
CONFIG_STACK_COLORATION=y
CONFIG_SIGINT_ACTION=y
CONFIG_START_DAY=10
CONFIG_START_MONTH=9
CONFIG_START_YEAR=2025
CONFIG_SYSTEM_NSH=y
CONFIG_SYSTEM_NSH_PRIORITY=100
CONFIG_SYSTEM_NSH_STACKSIZE=2048
CONFIG_USEC_PER_TICK=1000
CONFIG_SPINLOCK=y

CONFIG_MM_KERNEL_HEAPSIZE=262144

# FIX-055: vectors live at low address (ITCM 0x00000000); arm_head.S
# clears SCTLR.V when this is set. Combined with explicit VBAR write in
# rzv_start.c::rzv_set_vbar() so exceptions are routed to _vectors.
CONFIG_ARCH_LOWVECTORS=y

# FPU Configuration
CONFIG_ARCH_FPU=y
CONFIG_ARCH_DPFPU=y

# Debug features
CONFIG_DEBUG_GPIO=y
CONFIG_DEBUG_GPIO_ERROR=y
CONFIG_DEBUG_GPIO_WARN=y
CONFIG_DEBUG_GPIO_INFO=y

CONFIG_CPP_HAVE_VARARGS=y
