PROVIDE( __tls_base = ADDR (__ram_tdata$$));
PROVIDE( __tdata_source = LOADADDR (__ram_tdata$$));
PROVIDE( __tdata_size = SIZEOF (__ram_tdata$$));
PROVIDE( __tbss_offset = ADDR (__ram_tbss$$) - ADDR (__ram_tdata$$));
PROVIDE( __tbss_size = SIZEOF (__ram_tbss$$));
PROVIDE( __arm32_tls_tcb_offset = 8);

/* NuttX specific symbol definitions */
PROVIDE( _sinit = __init_array_start );
PROVIDE( _einit = __init_array_end );
PROVIDE( _sdata = ADDR(__ram_from_flash$$) );
PROVIDE( _edata = ADDR(__ram_from_flash$$) + SIZEOF(__ram_from_flash$$) );
PROVIDE( _stext = ADDR(__flash_readonly$$));
PROVIDE( _etext = ADDR(__flash_readonly$$) + SIZEOF(__flash_readonly$$) );
PROVIDE( _eronly = ADDR(__flash_readonly$$) + SIZEOF(__flash_readonly$$) );
PROVIDE( _sbss = ADDR(__ram_zero$$) );
PROVIDE( _ebss = ADDR(__ram_zero$$) + SIZEOF(__ram_zero$$) );