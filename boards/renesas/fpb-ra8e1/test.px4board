CONFIG_BOARD_TOOLCHAIN="arm-none-eabi"
CONFIG_BOARD_ARCHITECTURE="cortex-m85"
CONFIG_BOARD_CONSTRAINED_FLASH=y
CONFIG_BOARD_CONSTRAINED_MEMORY=y
CONFIG_BOARD_NO_HELP=y
CONFIG_ARM_MATH_NEON=n

# Test configuration - more verbose and debug features
CONFIG_BOARD_SERIAL_GPS1="/dev/ttyS0"
CONFIG_BOARD_SERIAL_TEL1="/dev/ttyS2"
CONFIG_BOARD_SERIAL_TEL2="/dev/ttyS3"

# NuttX specific config
CONFIG_BUILD_FLAT=y
CONFIG_ARCH_BOARD_CUSTOM=y  
CONFIG_ARCH_BOARD="fpb-ra8e1"
CONFIG_ARCH_BOARD_CUSTOM_DIR="boards/renesas/fpb-ra8e1"
CONFIG_ARCH_BOARD_CUSTOM_NAME="fpb-ra8e1"

# Test modules - minimal for hardware validation
CONFIG_MODULES_COMMANDER=y
CONFIG_MODULES_MAVLINK=y
CONFIG_MODULES_SENSORS=y
CONFIG_MODULES_DATAMAN=y

# Drivers for testing
CONFIG_DRIVERS_BAROMETER=y
CONFIG_DRIVERS_BAROMETER_BMP388=y
CONFIG_DRIVERS_IMU=y
CONFIG_DRIVERS_IMU_INVENSENSE_ICM20948=y
CONFIG_DRIVERS_PWM_OUT=y
CONFIG_DRIVERS_RC_INPUT=y
CONFIG_DRIVERS_TONE_ALARM=n

# System commands for testing
CONFIG_SYSTEMCMDS_ACTUATOR_TEST=y
CONFIG_SYSTEMCMDS_DMESG=y
CONFIG_SYSTEMCMDS_I2CDETECT=y
CONFIG_SYSTEMCMDS_LED_CONTROL=y
CONFIG_SYSTEMCMDS_PARAM=y
CONFIG_SYSTEMCMDS_PERF=y
CONFIG_SYSTEMCMDS_REBOOT=y
CONFIG_SYSTEMCMDS_TOP=y
CONFIG_SYSTEMCMDS_TOPIC_LISTENER=y
CONFIG_SYSTEMCMDS_UORB=y
CONFIG_SYSTEMCMDS_VER=y

# Test examples
CONFIG_EXAMPLES_HWTEST=y
CONFIG_EXAMPLES_PX4_SIMPLE_APP=y

# Board specific
CONFIG_BOARD_HAS_PWM=DEFINE_FROM_BOARDCONFIG
CONFIG_BOARD_PWM_SIM_DISABLED=DEFINE_FROM_BOARDCONFIG
CONFIG_BOARD_PWM_DRIVE_ACTIVE_LOW=DEFINE_FROM_BOARDCONFIG
