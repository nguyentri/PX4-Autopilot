{
    "configurations": [
        {
        "name": "Debug RA8P1 - Cortex-Debug",
        "cwd": "${workspaceRoot}",
        "executable": "${workspaceRoot}/platforms/nuttx/NuttX/nuttx/nuttx",
        "armToolchainPath": "/opt/arm-gnu-toolchain-13.2.Rel1/bin",
        "request": "launch",
        "type": "cortex-debug",
        "gdbPath": "/usr/bin/gdb-multiarch",
        "svdFile": "${workspaceRoot}/platforms/nuttx/NuttX/R7KA8P1AD.svd",
        "servertype": "jlink",
        "serverpath": "/opt/SEGGER/JLink/JLinkGDBServer",
        "serverArgs": [
          "-speed", "15000",
            // "-select", "IP=10.231.20.16:19023", // Need to check the IP address and Port of the JLink server
            // "-select", "IP=192.168.1.89:19023", // incase of running on wsl, need to run jlinkRemoteServer on windown
        ],
        "device": "R7KA8P1KF", // Base device name without package suffix
        // "serialNumber": "52006677", // 51028188/52006677/51026290
        "showDevDebugOutput": "parsed",
        // "runToEntryPoint": "main",
        "rttConfig": {
          "enabled": true,
          "address": "auto",
          "decoders": [
            {
              "label": "rtt_0",
              "port": 0,
              "type": "console",
            }
          ]
        },
        "liveWatch": {
          "enabled": true,
          "samplesPerSecond": 4
        },
        /* https://github.com/Marus/cortex-debug/issues/955#issuecomment-1806828308
            We have to reset after FW download, because we have no idea where you PC/SP are.
            Many devices use temporary FW to program the device. Besides, a 'reset' should always work.
            This is how 99% of devices work.
            If a reset causes a problem, should take it up with your device manufacturer and their openocd scripts.
            Btw, the Reset/Restart buttons also will not work.
        */
        "overrideLaunchCommands": [
          "monitor reset",    // Reset the target
          "monitor halt",     // Halt the target
          "load"              // Load the binary
          // "c"              // Continue the target (not be used in CR8)
        ],
      },
        {
            "name": "Debug RA8P1 - Renesas Extension",
            "type": "renesas-hardware",
            "request": "launch",
            "program": "${workspaceRoot}/platforms/nuttx/NuttX/nuttx/nuttx",
            "target": {
                "device": "R7KA8P1KF_CPU0",
                "deviceFamily": "RA",
                "debuggerType": "SEGGERJLINKARM"
            },
            "presentation": {
                "integerFormat": "hexadecimal"
            },
        },

    ]
  }
